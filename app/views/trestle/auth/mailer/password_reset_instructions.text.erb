<%= t("admin.auth.mailer.password_reset_instructions.greeting", default: "Hello %{email}!", email: @user.email) %>

<%= t("admin.auth.mailer.password_reset_instructions.message", default: "Someone has requested a link to change your password. You can do this through the link below.") %>

<%= trestle.edit_password_url(@user.password_reset_token) %>

<%= t("admin.auth.mailer.password_reset_instructions.ignore", default: "If you didn't request this, please ignore this email.") %>
<%= t("admin.auth.mailer.password_reset_instructions.unchanged", default: "Your password won't change until you access the link above and create a new one.") %>
